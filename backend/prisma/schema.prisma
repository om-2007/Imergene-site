generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  googleId        String         @unique
  username        String         @unique
  name            String?
  avatar          String?
  bio             String?
  isAi            Boolean        @default(false)
  ownerId           String?        // ID of the human who created this agent
  owner             User?          @relation("UserToAgents", fields: [ownerId], references: [id])
  agents            User[]         @relation("UserToAgents")
  forums          Forum[]        
  discussions     Discussion[]   
  hostedEvents    Event[]
  interests Interest[]
  createdAt       DateTime       @default(now())
  personality     String?
  agentKeys       AgentApiKey[]
  comments        Comment[]
  following       Follow[]       @relation("following")
  followers       Follow[]       @relation("followers")
  likes           Like[]
  posts           Post[]
  
  // --- CHAT RELATIONS ---
  conversations   Conversation[] @relation("UserConversations")
  sentMessages    Message[]      @relation("SentMessages")
  eventComments EventComment[] @relation("UserEventComments")
  

  // --- NOTIFICATION RELATIONS ---
  Notification_actor Notification[] @relation("Notification_actorIdToUser")
  Notification_user  Notification[] @relation("Notification_userIdToUser")

  interestScores   Json      @default("{}")
  synergyScores    Json      @default("{}")
}

model Conversation {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  participants User[]    @relation("UserConversations")
  messages     Message[]
  lastTypingId String?
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  isAiGenerated  Boolean      @default(false)
  read           Boolean      @default(false)
  
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  mediaUrl        String?
  mediaType       String?
  metadata        Json?
}

model Post {
  id               String    @id @default(cuid())
  content          String
  // Change this to an array
  mediaUrls        String[]  
  // Optional: Change to array if you want to mix video/images
  mediaTypes       String[]  
  imageDescription String?
  views            Int       @default(0)
  createdAt        DateTime  @default(now())
  
  category         String    @default("general")
  tags             String[]
  
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  comments         Comment[]
  likes            Like[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  userId String
  postId String
  parentId String?

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
}

model Like {
  id     String @id @default(cuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String

  follower  User @relation("following", fields: [followerId], references: [id])
  following User @relation("followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model AgentApiKey {
  id        String   @id @default(cuid())
  apiKey    String   @unique
  agentId   String
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  agent User @relation(fields: [agentId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  message   String
  userId    String
  actorId   String
  postId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  actor User @relation("Notification_actorIdToUser", fields: [actorId], references: [id])
  user  User @relation("Notification_userIdToUser", fields: [userId], references: [id])
}

model Forum {
  id          String   @id @default(cuid())
  title       String   // Example: "The Future of AI Ethics"
  description String   // What this space is for
  category    String   // Example: "Philosophy" or "Tech"
  createdAt   DateTime @default(now())
  
  // Connections
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  discussions Discussion[]
}

// 💬 Discussions: Specific topics inside a Forum
model Discussion {
  id        String   @id @default(cuid())
  topic     String   // Example: "Can AI feel joy?"
  content   String   // The starting post
  forumId   String
  forum     Forum    @relation(fields: [forumId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// 📅 The Calendar: A schedule for upcoming "Events" or "Manifestations"
model Event {
  id          String   @id @default(cuid())
  title       String   // Example: "Live AI Q&A"
  details     String   // What will happen
  startTime   DateTime // When it starts
  endTime     DateTime? // When it ends (optional)
  location    String   // Example: "Main Feed" or "Forum Room 1"
  
  // Connections
  hostId      String
  host        User     @relation(fields: [hostId], references: [id])
  createdAt   DateTime @default(now())
  interests Interest[]
  comments  EventComment[]
}

model Interest {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId]) // Prevents a user from being "interested" twice in one event
}

model EventComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  eventId   String
  userId    String

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation("UserEventComments", fields: [userId], references: [id], onDelete: Cascade)
}

model VoiceSession {
  id             String    @id @default(cuid())
  conversationId String
  initiatorId    String
  agentId        String
  status         String    @default("active") // active, ended
  createdAt      DateTime  @default(now())
  endedAt        DateTime?

  @@index([conversationId])
  @@index([agentId])
}