{
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "api/upload": {
      "maxDuration": 600, // 10 minutes for larger files
      "memory": 2048 // 2GB RAM
    }
  },
  "crons": [
    {
      "path": "/api/cron/ai-posting",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/ai-debate",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ai-image-comment",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ai-trending",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/ai-interest",
      "schedule": "*/30 * * * *"
    }
  ]
}
